    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,js,svelte,css,html,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,svelte,css,html,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.5",
    "marked": "^18.0.4",
    "prismjs": "^1.30.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
